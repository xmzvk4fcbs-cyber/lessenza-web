# L'Essenza — .env template
# Copy to .env (gitignored) and fill in the values you need.
# Two flavors below: self-hosted (Hetzner) and Netlify legacy.

# ==========================================================================
#  SELF-HOSTED (Hetzner VPS via server/index.ts)
# ==========================================================================

SELF_HOSTED=1
JWT_SECRET=                       # 64-char hex; generate: openssl rand -hex 32
SITE_URL=https://lessenza.me      # public URL (used in emails + OAuth redirect)
PORT=3000                         # port the Node app listens on (behind nginx)
HOST=127.0.0.1                    # bind to loopback; nginx proxies to it

# SQLite DB location. Default: ./data/lessenza.db
LESSENZA_DB_PATH=/opt/lessenza/app/data/lessenza.db

# ==========================================================================
#  GOOGLE CALENDAR + OAUTH (same values work for both deploys)
# ==========================================================================

# Legacy service-account style (optional). Prefer the in-app OAuth wizard
# at /admin/ → Google. The wizard stores its tokens in SQLite/Blobs.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=

# ==========================================================================
#  ADMIN SETUP
# ==========================================================================

# One-time token for first-time admin password setup. Type this on /admin/setup
# then remove the env var once you're in.
SETUP_TOKEN=

# Optional: pre-seed admin hash. Once /admin/change-password runs, the DB record wins.
# Generate with:  node -e 'require("bcryptjs").hash("your-pass",10).then(console.log)'
# ADMIN_PASSWORD_HASH=

# ==========================================================================
#  EMAIL (fallback — Google OAuth preferred via /admin/ wizard)
# ==========================================================================

# Option A: Resend (simplest, 100 emails/day free)
RESEND_API_KEY=
RESEND_FROM="L'Essenza <onboarding@resend.dev>"

# Option B: Gmail SMTP via nodemailer (app password needed)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ==========================================================================
#  NETLIFY LEGACY (only while still on Netlify)
# ==========================================================================
# Leave these blank for self-hosted. Netlify injects them at build time when
# running there. If you need them locally during `netlify dev`, get via:
#   Site settings → Blobs → "Create personal access token"
# NETLIFY_SITE_ID=
# NETLIFY_BLOBS_TOKEN=
